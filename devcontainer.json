{
    "name": "Laravel",
    "service": "cli",
    "remoteUser": "user",
    "shutdownAction": "stopCompose",
    "workspaceFolder": "/workspaces/laravel",
    "dockerComposeFile": "docker-compose.yaml",
    "customizations": {
        "vscode": {
            "extensions": [
                "bmewburn.vscode-intelephense-client",
                "eamodio.gitlens",
                "EditorConfig.EditorConfig",
                "mikestead.dotenv",
                "onecentlin.laravel-blade"
            ]
        }
    },
    "onCreateCommand": "composer global require laravel/installer",
    "remoteEnv": {
        "PATH": "${containerEnv:PATH}:/home/user/.composer/vendor/bin"
    }
}